#version 450
layout(local_size_x = 256) in;

layout(set = 0, binding = 0) buffer InOutA { float a[]; };
layout(set = 0, binding = 1) buffer readonly InB { float b[]; };
layout(set = 0, binding = 2) uniform Meta { uint length; };

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= length) return;
    a[i] += b[i];
}
