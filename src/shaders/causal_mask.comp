#version 450
layout(local_size_x = 16, local_size_y = 16) in;

layout(set = 0, binding = 0) buffer AttentionScores { float scores[]; };
layout(set = 0, binding = 1) uniform Meta {
    uint seq_len;
};

void main() {
    uint col = gl_GlobalInvocationID.x;
    uint row = gl_GlobalInvocationID.y;

    if (row >= seq_len || col >= seq_len) return;

    // just mask it
    if (col > row) {
        scores[row * seq_len + col] = -1e9; 
    }
}
