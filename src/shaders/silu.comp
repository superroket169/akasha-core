#version 450
layout(local_size_x = 256) in;

layout(set = 0, binding = 0) buffer InOut { float data[]; };
layout(set = 0, binding = 1) uniform Meta { uint length; };

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= length) return;
    
    float val = data[i];
    data[i] = val / (1.0 + exp(-val)); 
}
